# Generated candidate template. Publication requires separate authorization.

class Nostdb < Formula
  desc "NDB-first property graph database CLI"
  homepage "https://github.com/nostdb/nostdb-cli"
  version "@VERSION@"
  license "SSPL-1.0"

  on_arm do
    url "@ARM64_URL@"
    sha256 "@ARM64_SHA256@"
  end

  on_intel do
    url "@X64_URL@"
    sha256 "@X64_SHA256@"
  end

  def install
    bin.install "nostdb"
  end

  test do
    assert_equal "nostdb #{version}", shell_output("#{bin}/nostdb --version").strip
  end
end
